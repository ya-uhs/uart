<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UART.ViewModels"
             xmlns:models="using:UART.Models"
             mc:Ignorable="d"
             x:Class="UART.Views.TriggerView"
             x:DataType="vm:TriggerViewModel">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Header -->
    <Border Grid.Row="0" Background="#181825" Padding="6,4"
            BorderThickness="0,0,0,1" BorderBrush="#313244">
      <StackPanel Spacing="4">
        <TextBlock Text="Triggers" FontWeight="Bold" Foreground="#CDD6F4" FontSize="12" />
        <StackPanel Orientation="Horizontal" Spacing="4">
          <Button Content="+ Add" Command="{Binding AddTriggerCommand}"
                  Height="26" Padding="6,2"
                  ToolTip.Tip="Add trigger" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Trigger list -->
    <ListBox Grid.Row="1"
             ItemsSource="{Binding Triggers}"
             SelectedItem="{Binding SelectedTrigger}"
             Background="#11111B"
             Padding="4">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:TriggerItem">
          <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
            <!-- Enabled checkbox -->
            <CheckBox Grid.Column="0"
                      IsChecked="{Binding IsEnabled}"
                      VerticalAlignment="Center"
                      Margin="0,0,4,0" />
            <!-- Trigger name -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Name}"
                       VerticalAlignment="Center"
                       Foreground="#CDD6F4"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
            <!-- Delete button -->
            <Button Grid.Column="2"
                    Content="X"
                    Command="{Binding $parent[ListBox].((vm:TriggerViewModel)DataContext).RemoveTriggerCommand}"
                    CommandParameter="{Binding}"
                    Width="28" Height="28"
                    Foreground="#F38BA8" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Edit panel for selected trigger -->
    <Border Grid.Row="2" Background="#1E1E2E"
            Padding="8" BorderThickness="0,1,0,0" BorderBrush="#313244"
            IsVisible="{Binding SelectedTrigger, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Spacing="6">
        <TextBlock Text="Edit Trigger" FontSize="10" Foreground="#6C7086" />

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <!-- Name -->
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"
                     VerticalAlignment="Center" Margin="0,0,6,4" FontSize="12" Foreground="#BAC2DE" />
          <TextBox Grid.Row="0" Grid.Column="1"
                   Text="{Binding SelectedTrigger.Name}"
                   Margin="0,0,0,4" FontSize="12" />

          <!-- Pattern -->
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Pattern:"
                     VerticalAlignment="Center" Margin="0,0,6,4" FontSize="12" Foreground="#BAC2DE" />
          <TextBox Grid.Row="1" Grid.Column="1"
                   Text="{Binding SelectedTrigger.Pattern}"
                   FontFamily="Cascadia Code,Consolas,monospace"
                   Watermark="received string to match"
                   Margin="0,0,0,4" FontSize="12" />

          <!-- Response -->
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Response:"
                     VerticalAlignment="Center" Margin="0,0,6,4" FontSize="12" Foreground="#BAC2DE" />
          <TextBox Grid.Row="2" Grid.Column="1"
                   Text="{Binding SelectedTrigger.Response}"
                   FontFamily="Cascadia Code,Consolas,monospace"
                   Watermark="command to send"
                   Margin="0,0,0,4" FontSize="12" />

          <!-- Newline -->
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Newline:"
                     VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12" Foreground="#BAC2DE" />
          <ComboBox Grid.Row="3" Grid.Column="1"
                    ItemsSource="{Binding NewLineOptions}"
                    SelectedItem="{Binding SelectedTrigger.NewLine}"
                    FontSize="12" />
        </Grid>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
