<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:UART.ViewModels"
             mc:Ignorable="d"
             x:Class="UART.Views.TerminalView"
             x:DataType="vm:TerminalViewModel">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <Border Grid.Row="0" Background="#181825" Padding="6,4" BorderThickness="0,0,0,1" BorderBrush="#313244">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ToggleButton IsChecked="{Binding IsHexMode}"
                      Content="{Binding DisplayModeLabel}"
                      Width="60" Height="28"
                      ToolTip.Tip="Toggle HEX / ASCII display" />
        <ToggleButton IsChecked="{Binding AutoScroll}"
                      Content="AutoScroll"
                      Height="28"
                      ToolTip.Tip="Auto scroll to bottom" />
        <Button Content="Clear"
                Command="{Binding ClearTerminalCommand}"
                Height="28"
                ToolTip.Tip="Clear terminal" />
      </StackPanel>
    </Border>

    <!-- Terminal display -->
    <ScrollViewer Grid.Row="1"
                  Name="TerminalScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  Background="#11111B">
      <SelectableTextBlock Text="{Binding DisplayText}"
                           FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                           FontSize="13"
                           Foreground="#CDD6F4"
                           Padding="8"
                           TextWrapping="NoWrap" />
    </ScrollViewer>

    <!-- Send area -->
    <Border Grid.Row="2" Background="#1E1E2E" Padding="6" BorderThickness="0,1,0,0" BorderBrush="#313244">
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Name="SendTextBox"
                 Text="{Binding SendText}"
                 Watermark="Type command... (Up/Down for history)"
                 FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                 FontSize="13"
                 Margin="0,0,6,0" />
        <Button Grid.Column="1"
                Content="Send"
                Command="{Binding SendCommand}"
                Width="64"
                FontWeight="Bold" />
      </Grid>
    </Border>

  </Grid>
</UserControl>
