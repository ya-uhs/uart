<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UART.ViewModels"
        xmlns:views="using:UART.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="750"
        x:Class="UART.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="UART - Unified Avalonia Realtime Terminal"
        Width="1200" Height="750"
        MinWidth="800" MinHeight="500">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">

    <!-- 接続設定バー -->
    <views:ConnectionView Grid.Row="0"
                          DataContext="{Binding ConnectionViewModel}" />

    <!-- メインコンテンツ（マクロパネル + ターミナル） -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" MinWidth="120" MaxWidth="500" />
        <ColumnDefinition Width="4" />
        <ColumnDefinition Width="*" MinWidth="300" />
      </Grid.ColumnDefinitions>

      <!-- 左パネル: マクロ / トリガー タブ -->
      <TabControl Grid.Column="0" Padding="0">
        <TabItem Header="Macros">
          <views:MacroView DataContext="{Binding MacroViewModel}" />
        </TabItem>
        <TabItem Header="Triggers">
          <views:TriggerView DataContext="{Binding TriggerViewModel}" />
        </TabItem>
        <TabItem Header="Protocol">
          <views:ProtocolView DataContext="{Binding ProtocolViewModel}" />
        </TabItem>
      </TabControl>

      <!-- スプリッター -->
      <GridSplitter Grid.Column="1"
                    ResizeDirection="Columns"
                    Background="#313244"
                    Width="4" />

      <!-- ターミナル -->
      <views:TerminalView Grid.Column="2"
                          DataContext="{Binding TerminalViewModel}" />

    </Grid>
  </Grid>
</Window>
